# Copiar a .env en la raíz del monorepo y completar los valores.
# Nunca versionar .env con secretos reales.

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=alistamiento_db
MYSQL_USER=alistamiento_user
MYSQL_PASSWORD=change_me_db_password

# Backend
BACKEND_PORT=3000
JWT_SECRET=change_me_jwt_secret_min_32_chars
# python3 en Docker; opcional en dev local (ver Alistamiento_Backend/.env.example)
PYTHON_TIMEOUT_MS=120000

# Origen permitido por CORS (URL pública del frontend)
# Desarrollo local Docker: http://localhost
# Producción con HTTPS: https://tu-dominio.com
CORS_ORIGIN=http://localhost

# Frontend build (ruta relativa: nginx hace proxy a /api/)
VITE_API_URL=/api

# Puertos expuestos al host (solo nginx)
HTTP_PORT=80
HTTPS_PORT=443

# Nginx: dev por defecto; producción usar ./Alistamiento_Frontend/nginx.conf
NGINX_CONFIG=./Alistamiento_Frontend/nginx.conf.dev

# Certificados TLS para nginx.conf (producción)
# Debe contener fullchain.pem y privkey.pem
SSL_CERT_DIR=./certs
