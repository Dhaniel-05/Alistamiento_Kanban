PORT=3000
DB_HOST=localhost
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_database_name
JWT_SECRET=your_jwt_secret_here
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Intérprete Python para extracción PDF (autodetección: python3 en Docker/Linux)
# En Windows dev sin definir: usa .venv/Scripts/python.exe si existe
# PYTHON_BIN=python3
# Tiempo máximo del subprocess Python en milisegundos (default: 120000)
PYTHON_TIMEOUT_MS=120000
