# ===== Dependencias =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Lockfiles: descomenta UNO si decides NO versionarlos.
# Recomendación: versiónalos (no los ignores) para builds reproducibles.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ===== Variables de entorno (CRÍTICO) =====
.env
.env.*
!.env.example
!.env.*.example

# ===== Python (backend usa pdfplumber) =====
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# ===== Build / outputs =====
dist/
dist-ssr/
build/
.vite/
*.local
*.tsbuildinfo

# ===== Uploads (PDFs temporales, se procesan y borran) =====
# Ignora el contenido pero conserva la carpeta vía .gitkeep
**/uploads/*
!**/uploads/.gitkeep

# ===== Logs =====
logs/
*.log

# ===== Testing / cobertura =====
coverage/
.nyc_output/
*.test.js.snap

# ===== IDE / editores =====
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*.bak
*.sublime-project
*.sublime-workspace

# ===== OS =====
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ===== Caché / temporales =====
.cache/
*.tmp
*.temp
*.pid
*.pid.lock
*.seed

# ===== Bases de datos locales =====
*.sqlite
*.sqlite3
*.db

# ===== Certificados TLS (producción, no versionar) =====
certs/
*.pem
*.key
*.crt

# eliminar la carpeta de cursor IA si no se utiliza
.cursor\rules\seniorfullstack.mdc
